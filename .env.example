# Copy this file to .env and fill in real values.
# The .env file is git-ignored. NEVER commit real credentials.
#
# For the Cisco IOS-XE Always-On DevNet Sandbox, the published
# public credentials are:
#   DEVICE_HOST=sandbox-iosxe-latest-1.cisco.com
#   DEVICE_USERNAME=admin
#   DEVICE_PASSWORD=C1sco12345
#
# These are Cisco's public demo credentials — it is safe to use them
# against that specific public sandbox, but you should still keep
# them out of source control.

DEVICE_HOST=sandbox-iosxe-latest-1.cisco.com
DEVICE_PORT=22
DEVICE_USERNAME=admin
DEVICE_PASSWORD=C1sco12345
DEVICE_TYPE=cisco_xe
